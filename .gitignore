# ============================================================================
# Fireland .gitignore
# ============================================================================

# --- Build directories ---
build/
out/
cmake-build-*/

# --- IDE ---
.vs/
.vscode/
*.user
*.suo
*.sln.docstates
CMakeSettings.json
CMakePresets.json

# --- CMake generated ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
CTestTestfile.cmake

# --- Boost fetched sources (downloaded by FetchContent) ---
# These live in build/_deps/, not in-tree, so normally not needed.
# If for any reason they appear in the source tree:
3rdParty/boost/boost-*/

# --- Compiled output ---
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp

# --- Config files (keep .dist templates) ---
etc/*.conf
!etc/*.conf.dist

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- SQL dumps (local only) ---
sql/*.sql.local
